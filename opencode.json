{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "minimax": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "MiniMax",
      "options": {
        "baseURL": "https://api.minimax.io/v1"
      },
      "models": {
        "MiniMax-M3": {
          "name": "MiniMax M3",
          "limit": {
            "context": 1048576
          }
        }
      }
    }
  },
  "model": "minimax/MiniMax-M3",
  "mcp": {
    "hackernews": {
      "type": "local",
      "command": [
        "docker", "run", "-i", "--rm",
        "docker.io/mcp/hackernews-mcp"
      ]
    }
  }
}
